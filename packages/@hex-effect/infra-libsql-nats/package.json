{
  "name": "@hex-effect/infra-libsql-nats",
  "version": "0.2.3",
  "scripts": {
    "build": "rm -rf dist && bun build ./src/index.ts --packages 'external' --outdir ./dist --target node --sourcemap='linked' && tsc --emitDeclarationOnly --outDir ./dist",
    "check": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest"
  },
  "devDependencies": {
    "nanoid": "^5.1.7",
    "testcontainers": "^11.13.0"
  },
  "files": [
    "bin/",
    "dist/"
  ],
  "bin": {
    "geni": "./bin/geni-linux-amd64"
  },
  "type": "module",
  "peerDependencies": {
    "@effect/sql": ">=0.50.0",
    "@effect/sql-libsql": ">=0.40.0",
    "@libsql/client": ">=0.14.0",
    "effect": ">=3.20"
  },
  "dependencies": {
    "@hex-effect/core": "workspace:*",
    "@nats-io/jetstream": "^3.3.1",
    "@nats-io/transport-node": "^3.3.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "bun": "^1.3.11"
  },
  "exports": {
    "node": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "default": {
      "default": "./src/index.ts"
    }
  }
}
