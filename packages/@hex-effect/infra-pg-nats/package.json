{
  "name": "@hex-effect/infra-pg-nats",
  "version": "0.1.0",
  "scripts": {
    "build": "rm -rf dist && bun build ./src/index.ts --packages 'external' --outdir ./dist --target node --sourcemap='linked' && tsc --emitDeclarationOnly --outDir ./dist",
    "check": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "devDependencies": {
    "nanoid": "^5.1.7",
    "testcontainers": "^11.13.0"
  },
  "type": "module",
  "peerDependencies": {
    "@effect/sql": ">=0.51.0",
    "@effect/sql-pg": ">=0.51.0",
    "effect": ">=3.21"
  },
  "dependencies": {
    "@hex-effect/core": "workspace:*",
    "@hex-effect/infra-nats": "workspace:*",
    "@nats-io/jetstream": "^3.3.1",
    "@nats-io/transport-node": "^3.3.1"
  },
  "exports": {
    "node": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "default": {
      "default": "./src/index.ts"
    }
  }
}
