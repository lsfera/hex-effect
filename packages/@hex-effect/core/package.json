{
  "name": "@hex-effect/core",
  "version": "0.2.1",
  "scripts": {
    "build": "rm -rf dist && bun build ./index.ts --packages 'external' --outdir ./dist --target node --sourcemap='linked' && tsc --emitDeclarationOnly --outDir ./dist",
    "check": "tsc --noEmit",
    "lint": "eslint ."
  },
  "type": "module",
  "dependencies": {
    "nanoid": "~5.1.7"
  },
  "peerDependencies": {
    "effect": ">=3.20"
  },
  "exports": {
    "node": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "default": {
      "default": "./index.ts"
    }
  }
}
